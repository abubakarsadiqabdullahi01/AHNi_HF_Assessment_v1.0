# ---------------------------------------------------------------------
# Neon PostgreSQL connection string (server-side only — never expose it
# to client code). Copy this file to .env.local and paste YOUR string.
# Get it from: Neon Console -> your project -> Connection Details.
# ---------------------------------------------------------------------

DATABASE_URL='postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require'

# On Vercel: add DATABASE_URL under Project -> Settings -> Environment Variables,
# or attach Vercel Postgres (which sets POSTGRES_URL, used as a fallback).

# ---------------------------------------------------------------------
# Admin access token — gates /admin (the response viewer) and the
# /api/responses and /api/export endpoints. Use a long random string.
# If unset, the admin endpoints deny all access (fail closed).
# ---------------------------------------------------------------------
ADMIN_TOKEN='choose-a-long-random-string'
